<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Toolbar (id topBarSettings для WindowInsets) -->
    <LinearLayout
        android:id="@+id/topBarSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A1A">

        <!-- Status bar spacer (заполняется в коде) -->
        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:tint="#FFFFFF"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Настройки"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section: Display -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЭКРАН"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <!-- Fullscreen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Полноэкранный режим"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchFullscreen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Section: Marker -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="МАРКЕР ПОЗИЦИИ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <!-- Marker color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Цвет маркера"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <!-- Color swatches -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View android:id="@+id/colorRed"    android:layout_width="28dp" android:layout_height="28dp" android:background="#FF2200" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorOrange" android:layout_width="28dp" android:layout_height="28dp" android:background="#FF6F00" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorBlue"   android:layout_width="28dp" android:layout_height="28dp" android:background="#1565C0" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorGreen"  android:layout_width="28dp" android:layout_height="28dp" android:background="#2E7D32" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorWhite"  android:layout_width="28dp" android:layout_height="28dp" android:background="#FFFFFF" android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Marker size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Размер маркера"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/txtMarkerSize"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="56"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekMarkerSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:min="24"
                    android:max="96"
                    android:progress="56" />
            </LinearLayout>

            <!-- Section: Controls -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="УПРАВЛЕНИЕ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Кнопки громкости — зум"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchVolumeZoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- Section: Files -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ФАЙЛЫ ТРЕКОВ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnLoadFile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Загрузить трек (GPX, WPT, RTE, PLT)"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A2A2A"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtLoadedFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:paddingStart="4dp" />

            <!-- Section: About -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="О ПРИЛОЖЕНИИ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="16dp">
                <TextView
                    android:id="@+id/txtVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trophy Navigator"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Навигация для трофи-рейдов"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">
                    <Button
                        android:id="@+id/btnCheckUpdates"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Проверить обновления"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2A2A2A"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                    <TextView
                        android:id="@+id/txtUpdateStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:layout_marginStart="10dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
