<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Toolbar (id topBarSettings для WindowInsets) -->
    <LinearLayout
        android:id="@+id/topBarSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A1A">

        <!-- Status bar spacer (заполняется в коде) -->
        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:tint="#FFFFFF"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Настройки"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section: Display -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЭКРАН"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <!-- Fullscreen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Полноэкранный режим"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchFullscreen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Section: Marker -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="МАРКЕР ПОЗИЦИИ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <!-- Marker color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Цвет маркера"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <!-- Color swatches -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View android:id="@+id/colorGold"   android:layout_width="28dp" android:layout_height="28dp" android:background="#FFD600" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorRed"    android:layout_width="28dp" android:layout_height="28dp" android:background="#FF2200" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorOrange" android:layout_width="28dp" android:layout_height="28dp" android:background="#FF6F00" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorBlue"   android:layout_width="28dp" android:layout_height="28dp" android:background="#1565C0" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorGreen"  android:layout_width="28dp" android:layout_height="28dp" android:background="#2E7D32" android:layout_marginStart="6dp" />
                    <View android:id="@+id/colorWhite"  android:layout_width="28dp" android:layout_height="28dp" android:background="#FFFFFF" android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Marker size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Размер маркера"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/txtMarkerSize"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="56"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekMarkerSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:min="24"
                    android:max="96"
                    android:progress="56" />
            </LinearLayout>

            <!-- Section: Controls -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="УПРАВЛЕНИЕ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Кнопки громкости — зум"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchVolumeZoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- Keep screen on -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Экран всегда включён"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchKeepScreen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- Track recording interval -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Интервал записи трека (сек)"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <ImageButton
                    android:id="@+id/btnIntervalMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_remove"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/txtTrackInterval"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center" />
                <ImageButton
                    android:id="@+id/btnIntervalPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Recording track color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Цвет трека записи"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View android:id="@+id/trackRecColorRed"    android:layout_width="26dp" android:layout_height="26dp" android:background="#FF2200" android:layout_marginStart="5dp" />
                    <View android:id="@+id/trackRecColorOrange" android:layout_width="26dp" android:layout_height="26dp" android:background="#FF6F00" android:layout_marginStart="5dp" />
                    <View android:id="@+id/trackRecColorYellow" android:layout_width="26dp" android:layout_height="26dp" android:background="#FFD600" android:layout_marginStart="5dp" />
                    <View android:id="@+id/trackRecColorGreen"  android:layout_width="26dp" android:layout_height="26dp" android:background="#2E7D32" android:layout_marginStart="5dp" />
                    <View android:id="@+id/trackRecColorBlue"   android:layout_width="26dp" android:layout_height="26dp" android:background="#1565C0" android:layout_marginStart="5dp" />
                    <View android:id="@+id/trackRecColorWhite"  android:layout_width="26dp" android:layout_height="26dp" android:background="#FFFFFF" android:layout_marginStart="5dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Recording track width -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="1dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Толщина трека записи"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <ImageButton
                    android:id="@+id/btnTrackWidthMinus"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_remove"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/txtTrackWidth"
                    android:layout_width="32dp" android:layout_height="wrap_content"
                    android:text="4"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center" />
                <ImageButton
                    android:id="@+id/btnTrackWidthPlus"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Save current track button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Сохранить текущий трек"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <Button
                    android:id="@+id/btnSaveTrack"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="GPX"
                    android:textSize="13sp"
                    android:backgroundTint="#FF6F00"
                    android:textColor="#FFFFFF"
                    style="?attr/materialButtonStyle" />
            </LinearLayout>

            <!-- Follow mode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Режим следования"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:layout_marginBottom="8dp" />
                <RadioGroup
                    android:id="@+id/rgFollowMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <RadioButton android:id="@+id/rbFollowFree"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Свободный" android:textColor="#CCCCCC" android:textSize="14sp" />
                    <RadioButton android:id="@+id/rbFollowNorth"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Следить — север вверху" android:textColor="#CCCCCC" android:textSize="14sp" />
                    <RadioButton android:id="@+id/rbFollowCourse"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Следить — курс вверху" android:textColor="#CCCCCC" android:textSize="14sp" />
                </RadioGroup>
            </LinearLayout>

            <!-- 3D tilt on speed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3D наклон при движении"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch3dTilt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Auto-zoom by speed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Авто-масштаб по скорости"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <ImageButton
                    android:id="@+id/btnAutoZoomMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_remove"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/txtAutoZoom"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="Выкл"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center" />
                <ImageButton
                    android:id="@+id/btnAutoZoomPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Cursor vertical offset -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Курсор ниже центра"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <ImageButton
                    android:id="@+id/btnCursorOffsetMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_remove"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/txtCursorOffset"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center" />
                <ImageButton
                    android:id="@+id/btnCursorOffsetPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Автовозврат к позиции"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoRecenter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Auto-recenter delay -->
            <LinearLayout
                android:id="@+id/rowRecenterDelay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="32dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="1dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Задержка (сек)"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />
                <ImageButton
                    android:id="@+id/btnRecenterDelayMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_remove"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/txtRecenterDelay"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center" />
                <ImageButton
                    android:id="@+id/btnRecenterDelayPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Section: Widgets -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ВИДЖЕТЫ НА КАРТЕ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Переключатель — вкл/выкл. Стрелки — порядок отображения."
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <!-- Dynamic widget order list (built in code) -->
            <LinearLayout
                android:id="@+id/widgetOrderContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Section: Files -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ФАЙЛЫ КАРТЫ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnLoadFile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Загрузить файл (GPX, WPT, RTE, PLT)"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A2A2A"
                android:textSize="14sp" />

            <!-- Loaded track row -->
            <LinearLayout
                android:id="@+id/rowLoadedTrack"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginTop="4dp">
                <TextView
                    android:id="@+id/txtLoadedTrack"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:paddingStart="4dp" />
                <ImageButton
                    android:id="@+id/btnToggleTrack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_eye"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Loaded track style (color + width), shown when track is loaded -->
            <LinearLayout
                android:id="@+id/rowLoadedTrackStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="#171717"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Цвет трека"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:paddingStart="4dp" />
                    <View android:id="@+id/loadedTrackColorBlue"   android:layout_width="26dp" android:layout_height="26dp" android:background="#2196F3" android:layout_marginStart="5dp" />
                    <View android:id="@+id/loadedTrackColorRed"    android:layout_width="26dp" android:layout_height="26dp" android:background="#FF2200" android:layout_marginStart="5dp" />
                    <View android:id="@+id/loadedTrackColorOrange" android:layout_width="26dp" android:layout_height="26dp" android:background="#FF6F00" android:layout_marginStart="5dp" />
                    <View android:id="@+id/loadedTrackColorGreen"  android:layout_width="26dp" android:layout_height="26dp" android:background="#2E7D32" android:layout_marginStart="5dp" />
                    <View android:id="@+id/loadedTrackColorYellow" android:layout_width="26dp" android:layout_height="26dp" android:background="#FFD600" android:layout_marginStart="5dp" />
                    <View android:id="@+id/loadedTrackColorWhite"  android:layout_width="26dp" android:layout_height="26dp" android:background="#FFFFFF" android:layout_marginStart="5dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Толщина"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:paddingStart="4dp" />
                    <ImageButton
                        android:id="@+id/btnLoadedTrackWidthMinus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_remove"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="#AAAAAA" />
                    <TextView
                        android:id="@+id/txtLoadedTrackWidth"
                        android:layout_width="32dp" android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="#AAAAAA"
                        android:textSize="15sp"
                        android:gravity="center" />
                    <ImageButton
                        android:id="@+id/btnLoadedTrackWidthPlus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_add"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="#AAAAAA" />
                </LinearLayout>
            </LinearLayout>

            <!-- Loaded waypoints row -->
            <LinearLayout
                android:id="@+id/rowLoadedWp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/txtLoadedWp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:paddingStart="4dp" />
                    <ImageButton
                        android:id="@+id/btnToggleWp"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_eye"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="#FFFFFF" />
                </LinearLayout>

                <!-- Navigation start/stop buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <Button
                        android:id="@+id/btnNavStart"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="▶ Навигация"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E20"
                        android:layout_marginEnd="4dp" />
                    <Button
                        android:id="@+id/btnNavStop"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="■ Стоп"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B71C1C"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- keep old id for compat -->
            <TextView
                android:id="@+id/txtLoadedFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF6B6B"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:visibility="gone" />

            <!-- Section: Offline maps -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ОФФЛАЙН КАРТЫ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnLoadOfflineMap"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Загрузить карту (RMaps, MBTiles)"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A2A2A"
                android:textSize="14sp" />

            <!-- Dynamic list of offline maps -->
            <LinearLayout
                android:id="@+id/containerOfflineMaps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />

            <!-- Section: Cache -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="КЭШ КАРТ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1E1E1E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Размер кэша (МБ)"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <ImageButton
                    android:id="@+id/btnCacheMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_remove"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/txtCacheMb"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="200"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:gravity="center" />
                <ImageButton
                    android:id="@+id/btnCachePlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Section: Sync -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="СИНХРОНИЗАЦИЯ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ключ активации (TND-XXXX-XXXX-XXXX)"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/editSyncApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="TND-XXXX-XXXX-XXXX"
                    android:hintTextColor="#555555"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="#2A2A2A"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionDone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <Button
                        android:id="@+id/btnSyncPull"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="⬇ Получить КП"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1565C0"
                        android:layout_marginEnd="6dp" />

                    <Button
                        android:id="@+id/btnSyncPush"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="⬆ Отправить трек"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E20"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtSyncStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Section: About -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="О ПРИЛОЖЕНИИ"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="16dp">
                <TextView
                    android:id="@+id/txtVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trophy Navigator"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Навигация для трофи-рейдов"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">
                    <Button
                        android:id="@+id/btnCheckUpdates"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Проверить обновления"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2A2A2A"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                    <TextView
                        android:id="@+id/txtUpdateStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:layout_marginStart="10dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
