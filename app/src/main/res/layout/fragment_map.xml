<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Full-screen map -->
    <com.mapbox.mapboxsdk.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top toolbar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="2dp"
        android:background="#CC1A1A1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Compass -->
        <com.andreykoff.racenav.CompassView
            android:id="@+id/compassView"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="Compass" />

        <!-- Zoom In — left side, next to compass -->
        <ImageButton
            android:id="@+id/btnZoomIn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zoom in"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <!-- Zoom Out — left side, next to zoom in -->
        <ImageButton
            android:id="@+id/btnZoomOut"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_remove"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zoom out"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <!-- Add marker at current position -->
        <ImageButton
            android:id="@+id/btnAddWaypoint"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_add_waypoint"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add marker"
            android:padding="5dp" />

        <!-- Quick actions menu -->
        <ImageButton
            android:id="@+id/btnQuickAction"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_folder"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quick actions"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#444444"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- STOP navigation -->
        <TextView
            android:id="@+id/btnWidgetStop"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="■"
            android:textSize="18sp"
            android:textColor="#666666"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Push remaining buttons to right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- GO navigation -->
        <TextView
            android:id="@+id/btnWidgetGo"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="GO"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#666666"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Battery indicator (top bar) -->
        <TextView
            android:id="@+id/btnBatteryIndicator"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="--"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:visibility="gone" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#444444"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- Layers -->
        <ImageButton
            android:id="@+id/btnLayers"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_layers"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Layers"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <!-- REC -->
        <ImageButton
            android:id="@+id/btnRec"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_rec_start"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Record track"
            android:padding="5dp" />

        <!-- Lock screen -->
        <ImageButton
            android:id="@+id/btnLock"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_lock"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Lock screen"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <!-- Quick map switch -->
        <ImageButton
            android:id="@+id/btnMapSwitch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_swap_map"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch map"
            android:tint="#FFFFFF"
            android:padding="5dp"
            android:visibility="gone" />

        <!-- Server status indicator in top bar -->
        <View
            android:id="@+id/topBarServerDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_dot"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#444444"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- Settings -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:tint="#FFFFFF"
            android:padding="5dp" />

    </LinearLayout>

    <!-- Waypoint navigation bar (prev/next CP buttons), shown when navigation active -->
    <LinearLayout
        android:id="@+id/waypointNavBar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#CC1A1A1A"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnPrevWp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Предыдущий WP"
            android:padding="10dp" />

        <TextView
            android:id="@+id/txtWpNavInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WP 1/1: —"
            android:textColor="#FF6F00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:singleLine="true"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btnNextWp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_right"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Следующий WP"
            android:padding="10dp" />

    </LinearLayout>

    <!-- Bottom widget bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="68dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:background="#CC1A1A1A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- STOP navigation button (shown when waypoints loaded) -->
        <!-- GO/STOP moved to waypointNavBar -->

        <!-- Speed -->
        <LinearLayout
            android:id="@+id/widgetSpeedContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="км/ч"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Direction arrow -->
        <LinearLayout
            android:id="@+id/widgetBearingContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/widgetDirectionArrow"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_arrow"
                android:contentDescription="Direction" />
            <TextView
                android:id="@+id/widgetBearing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---°"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Track length -->
        <LinearLayout
            android:id="@+id/widgetTrackLenContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetTrackLen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="км трек"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Next CP distance -->
        <LinearLayout
            android:id="@+id/widgetNextCpContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetNextCp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="след.WP"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Altitude -->
        <LinearLayout
            android:id="@+id/widgetAltitudeContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetAltitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="м высота"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Chronometer (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetChronoContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetChrono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="хронометр"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Current time (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetTimeContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="время"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Remaining km on route (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetRemainKmContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetRemainKm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="км ост."
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Next CP name (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetNextCpNameContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetNextCpName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:maxWidth="80dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="имя WP"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Tripmaster (resettable distance, initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetTripmasterContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetTripmaster"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="#00E676"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="трип км"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Server status widget (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetServerStatusContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <View
                android:id="@+id/widgetServerDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/circle_dot" />
            <TextView
                android:id="@+id/widgetServerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="сервер"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- GO navigation button (shown when waypoints loaded) -->
        <!-- GO moved to waypointNavBar -->

        <!-- Battery -->
        <LinearLayout
            android:id="@+id/widgetBatteryContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="% бат."
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Legacy traccarSyncDot removed — replaced by widget and topBar indicator -->

    <ImageView
        android:id="@+id/crosshairView"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="@id/mapView"
        app:layout_constraintBottom_toBottomOf="@id/mapView"
        app:layout_constraintStart_toStartOf="@id/mapView"
        app:layout_constraintEnd_toEndOf="@id/mapView" />

    <!-- Lock overlay: transparent touch blocker, lock icon bottom-left -->

    <!-- Distance line label (center-bottom of crosshair) -->
    <TextView
        android:id="@+id/distanceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:background="#99000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:visibility="gone"
        android:elevation="3dp"
        app:layout_constraintTop_toBottomOf="@id/crosshairView"
        app:layout_constraintStart_toStartOf="@id/mapView"
        app:layout_constraintEnd_toEndOf="@id/mapView"
        android:layout_marginTop="4dp" />

    <!-- Coordinates label (top center, landscape only) -->
    <TextView
        android:id="@+id/coordsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:background="#66000000"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:visibility="gone"
        android:elevation="3dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp" />

    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="14dp"
            android:src="@drawable/ic_lock"
            android:tint="#FFD600"
            android:alpha="0.9"
            android:background="@drawable/rounded_bg_dark"
            android:padding="4dp" />
    </FrameLayout>

    <!-- Download progress indicator -->
    <FrameLayout
        android:id="@+id/downloadIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_bg_dark"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ProgressBar
                android:id="@+id/dlProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/dlProgressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Emergency settings button — shown when all panels are hidden (4s press on map) -->
    <ImageButton
        android:id="@+id/btnEmergencySettings"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_settings"
        android:background="@android:color/transparent"
        android:tint="#FFFFFF"
        android:alpha="0.35"
        android:padding="10dp"
        android:visibility="gone"
        android:contentDescription="Настройки"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
