<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Full-screen map -->
    <com.mapbox.mapboxsdk.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top toolbar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="2dp"
        android:background="#CC1A1A1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Compass -->
        <ImageView
            android:id="@+id/compassView"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_compass"
            android:contentDescription="Compass"
            android:padding="4dp" />

        <!-- Zoom In — left side, next to compass -->
        <ImageButton
            android:id="@+id/btnZoomIn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zoom in"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <!-- Zoom Out — left side, next to zoom in -->
        <ImageButton
            android:id="@+id/btnZoomOut"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_remove"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zoom out"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#444444"
            android:layout_marginStart="1dp"
            android:layout_marginEnd="1dp" />

        <!-- Push remaining buttons to right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#444444"
            android:layout_marginStart="1dp"
            android:layout_marginEnd="1dp" />

        <!-- Layers -->
        <ImageButton
            android:id="@+id/btnLayers"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_layers"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Layers"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <!-- REC -->
        <ImageButton
            android:id="@+id/btnRec"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_rec_start"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Record track"
            android:padding="5dp" />

        <!-- Lock screen -->
        <ImageButton
            android:id="@+id/btnLock"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_lock"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Lock screen"
            android:tint="#FFFFFF"
            android:padding="5dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#444444"
            android:layout_marginStart="1dp"
            android:layout_marginEnd="1dp" />

        <!-- Settings -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:tint="#FFFFFF"
            android:padding="5dp" />

    </LinearLayout>

    <!-- Waypoint navigation bar (prev/next CP buttons), shown when navigation active -->
    <LinearLayout
        android:id="@+id/waypointNavBar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#CC1A1A1A"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnPrevWp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Предыдущий КП"
            android:padding="10dp" />

        <TextView
            android:id="@+id/txtWpNavInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="КП 1/1: —"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:singleLine="true"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btnNextWp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_right"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Следующий КП"
            android:padding="10dp" />

    </LinearLayout>

    <!-- Bottom widget bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:background="#CC1A1A1A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Speed -->
        <LinearLayout
            android:id="@+id/widgetSpeedContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="км/ч"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Direction arrow -->
        <LinearLayout
            android:id="@+id/widgetBearingContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/widgetDirectionArrow"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_arrow"
                android:contentDescription="Direction" />
            <TextView
                android:id="@+id/widgetBearing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---°"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Track length -->
        <LinearLayout
            android:id="@+id/widgetTrackLenContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetTrackLen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="км трек"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Next CP distance -->
        <LinearLayout
            android:id="@+id/widgetNextCpContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetNextCp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="след.КП"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Altitude -->
        <LinearLayout
            android:id="@+id/widgetAltitudeContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/widgetAltitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="м высота"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Chronometer (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetChronoContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetChrono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="хронометр"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Current time (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetTimeContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="время"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Remaining km on route (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetRemainKmContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetRemainKm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="км ост."
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Next CP name (initially hidden) -->
        <LinearLayout
            android:id="@+id/widgetNextCpNameContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:id="@+id/widgetNextCpName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:maxWidth="80dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="имя КП"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Lock overlay: transparent touch blocker, lock icon bottom-left -->
    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="14dp"
            android:layout_marginBottom="14dp"
            android:src="@drawable/ic_lock"
            android:alpha="0.75" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
